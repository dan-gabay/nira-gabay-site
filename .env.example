# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Draft-mode preview link secret - gates /api/preview, used by the
# /manage/articles "preview" button to view unpublished drafts. Any random
# string; generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
NEXT_PUBLIC_PREVIEW_SECRET=your-random-secret

# Google Analytics 4 measurement ID (GA4 Admin > Data Streams > Web).
# Optional - components/GoogleAnalytics.tsx falls back to the site's real ID.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# GA4 reporting API access (read-only, used by scripts/ga-*.ts, never by the
# site itself). Reuses the GSC OAuth client below; run scripts/ga-auth.ts to
# get the refresh token, scripts/ga-list-properties.ts to find the property ID.
GA_REFRESH_TOKEN=your-refresh-token
GA_PROPERTY_ID=123456789

# Google Search Console API access (read-only, used by scripts/gsc-*.ts).
# OAuth desktop-app client from Google Cloud Console; run scripts/gsc-auth.ts.
GSC_CLIENT_ID=your-oauth-client-id
GSC_CLIENT_SECRET=your-oauth-client-secret
GSC_REFRESH_TOKEN=your-refresh-token
