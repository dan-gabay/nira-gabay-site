{
  "crons": [
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "*/5 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "niragabay.com"
        }
      ],
      "destination": "https://www.niragabay.com/:path*",
      "permanent": true
    }
  ]
}
